# 自动检测文本文件并规范化换行符
* text=auto

# Python 文件 - LF 换行符
*.py text eol=lf
*.pyi text eol=lf

# 前端文件 - LF 换行符
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# 文档 - LF 换行符
*.md text eol=lf
*.txt text eol=lf

# 配置文件 - LF 换行符
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
.env.example text eol=lf

# Windows 批处理 - CRLF 换行符
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件 - 不处理换行符
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.pyc binary
*.pyd binary
*.dll binary
*.exe binary
*.rar binary
*.zip binary
*.7z binary
